<UserControl x:Class="JBI.WorkshopManager.UI.Views.WorkOrders.NewWorkOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock
                Text="New Work Order"
                FontSize="28"
                FontWeight="Bold"/>

            <!-- Form -->
            <Border Grid.Row="2"
                    Padding="25"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="8">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>

                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <!-- Work Order -->

                    <TextBlock
                        Text="Work Order Number:"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Grid.Column="1"
                        Text="{Binding WorkOrderNumber}"
                        Height="28"/>

                    <!-- Machine -->

                    <TextBlock
                        Grid.Row="2"
                        Text="Machine:"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Text="{Binding MachineName}"
                        Height="28"/>

                    <!-- Item Code -->

                    <TextBlock
                        Grid.Row="4"
                        Text="Item Code:"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Grid.Row="4"
                        Grid.Column="1"
                        Text="{Binding ItemCode}"
                        Height="28"/>

                    <!-- Quantity -->

                    <TextBlock
                        Grid.Row="6"
                        Text="Quantity:"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Grid.Row="6"
                        Grid.Column="1"
                        Text="{Binding Quantity}"
                        Height="28"/>

                    <!-- Order Date -->

                    <TextBlock
                        Grid.Row="8"
                        Text="Order Date:"
                        VerticalAlignment="Center"/>

                    <DatePicker
                        Grid.Row="8"
                        Grid.Column="1"
                        SelectedDate="{Binding OrderDate}"/>

                    <!-- Due Date -->

                    <TextBlock
                        Grid.Row="10"
                        Text="Due Date:"
                        VerticalAlignment="Center"/>

                    <DatePicker
                        Grid.Row="10"
                        Grid.Column="1"
                        SelectedDate="{Binding DueDate}"/>

                    <!-- Button -->

                    <Button
                        Grid.Row="14"
                        Grid.ColumnSpan="2"
                        Content="Create Work Order"
                        Width="180"
                        Height="40"
                        HorizontalAlignment="Center"
                        Command="{Binding CreateWorkOrderCommand}"/>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</UserControl>