<UserControl x:Class="JBI.WorkshopManager.UI.Views.MachineCatalogueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Machine Catalogue"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Data -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Machines}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Item Code"
                    Binding="{Binding ItemCode}" />

                <DataGridTextColumn
                    Header="Machine"
                    Binding="{Binding MachineName}" />

                <DataGridTextColumn
                    Header="Category"
                    Binding="{Binding Category}" />

                <DataGridTextColumn
                    Header="Std Build Hours"
                    Binding="{Binding StandardBuildHours}" />

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>