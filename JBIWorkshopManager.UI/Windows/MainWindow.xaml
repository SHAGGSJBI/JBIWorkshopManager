<Window x:Class="JBI.WorkshopManager.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JBI.WorkshopManager.UI.Windows"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}" Height="450" Width="800">
    <DockPanel>

        <!-- Top Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File"/>
            <MenuItem Header="_Workshop"/>
            <MenuItem Header="_Inventory"/>
            <MenuItem Header="_Purchasing"/>
            <MenuItem Header="_Reports"/>
            <MenuItem Header="_Help"/>
        </Menu>

        <!-- Bottom Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="Ready"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ApplicationTitle}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Left Navigation -->
        <Border Width="220"
            DockPanel.Dock="Left"
            BorderBrush="LightGray"
            BorderThickness="0,0,1,0">

            <StackPanel Margin="10">

                <Button Content="Dashboard" Margin="0,5"/>
                <Button Content="Workshop Jobs" Margin="0,5"/>
                <Button Content="Customers" Margin="0,5"/>
                <Button Content="Machines" Margin="0,5"/>
                <Button Content="Inventory" Margin="0,5"/>
                <Button Content="Purchasing" Margin="0,5"/>
                <Button Content="Reports" Margin="0,5"/>
                <Button Content="Settings" Margin="0,5"/>

            </StackPanel>

        </Border>

        <!-- Main Workspace -->
        <Grid Margin="15">

            <ContentControl
        Content="{Binding CurrentViewModel}" />

        </Grid>

    </DockPanel>

</Window>