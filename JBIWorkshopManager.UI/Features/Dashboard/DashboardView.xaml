<UserControl x:Class="JBI.WorkshopManager.UI.Features.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:JBI.WorkshopManager.UI.Features.Dashboard.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <TextBlock
                Text="Dashboard"
                FontSize="30"
                FontWeight="Bold"
                Margin="0,0,0,20"/>

            <UniformGrid Columns="3">

                <controls:DashboardCard
                    Title="Active Work Orders"
                    Value="18"/>

                <controls:DashboardCard
                    Title="Waiting on Steel"
                    Value="2"/>

                <controls:DashboardCard
                    Title="Waiting on CNC"
                    Value="4"/>

                <controls:DashboardCard
                    Title="Low Stock Parts"
                    Value="16"/>

                <controls:DashboardCard
                    Title="Completed Today"
                    Value="7"/>

                <controls:DashboardCard
                    Title="Machines"
                    Value="164"/>

            </UniformGrid>

        </StackPanel>

    </ScrollViewer>

</UserControl>