<UserControl x:Class="JBI.WorkshopManager.UI.Controls.KpiCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Margin="8"
        Padding="16"
        CornerRadius="8"
        BorderThickness="1"
        BorderBrush="LightGray"
        Background="White">

        <StackPanel>

            <TextBlock
                x:Name="TitleText"
                Text="Title"
                FontWeight="SemiBold"
                FontSize="14"/>

            <TextBlock
                x:Name="ValueText"
                Text="0"
                Margin="0,12,0,0"
                FontSize="32"
                FontWeight="Bold"
                HorizontalAlignment="Center"/>

        </StackPanel>

    </Border>

</UserControl>