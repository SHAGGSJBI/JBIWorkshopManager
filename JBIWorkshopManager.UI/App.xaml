    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="Resources/ViewTemplates.xaml"/>

                <ResourceDictionary Source="Resources/Themes/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Typography.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Layout.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Controls.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>

</Application>