<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary -->
    <Color x:Key="Color.Primary">#FF005A9E</Color>

    <!-- Secondary -->
    <Color x:Key="Color.Secondary">#FF2D2D30</Color>

    <!-- Accent -->
    <Color x:Key="Color.Accent">#FF007ACC</Color>

    <!-- Background -->
    <Color x:Key="Color.Background">#FFF5F5F5</Color>

    <!-- Surface -->
    <Color x:Key="Color.Surface">White</Color>

</ResourceDictionary>