<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush
        x:Key="Brush.Primary"
        Color="{StaticResource Color.Primary}" />

    <SolidColorBrush
        x:Key="Brush.Background"
        Color="{StaticResource Color.Background}" />

    <SolidColorBrush
        x:Key="Brush.Surface"
        Color="{StaticResource Color.Surface}" />

</ResourceDictionary>