<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Font -->
    <FontFamily x:Key="Font.Default">Segoe UI</FontFamily>

    <!-- Sizes -->
    <sys:Double x:Key="FontSize.Small">12</sys:Double>
    <sys:Double x:Key="FontSize.Normal">14</sys:Double>
    <sys:Double x:Key="FontSize.Large">18</sys:Double>
    <sys:Double x:Key="FontSize.Title">28</sys:Double>

</ResourceDictionary>